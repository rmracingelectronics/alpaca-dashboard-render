# Copy this file to .env locally. Do not commit your real .env.
# On Render, add these as environment variables instead.

# Alpaca paper API keys only for this deployment.
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_ACCOUNT_ID=your_paper_account_id_here
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_FEED=iex

# Shared live state. Leave blank locally to use SQLite. Render sets this from the managed Postgres database.
DATABASE_URL=

# Dash web app.
DASH_DEBUG=false

# Paper worker safety gates.
# V33 is configured for automatic Alpaca paper order placement.
# Set PAPER_TRADING_DRY_RUN=true if you want to log plans without submitting orders.
PAPER_TRADING_ENABLED=true
PAPER_TRADING_DRY_RUN=false
# This must remain false unless you intentionally rebuild the app for live trading.
ALLOW_LIVE_TRADING=false

# Live scanning universe. Leave LIVE_SYMBOLS blank to use LIVE_WATCHLIST_PRESET.
LIVE_WATCHLIST_PRESET=v25_playbook
LIVE_SYMBOLS=
LIVE_LOOKBACK_DAYS=75
LIVE_INCREMENTAL_FETCH_DAYS=3
LIVE_POLL_SECONDS=60
LIVE_REQUIRE_MARKET_OPEN=true
LIVE_ENABLE_MAX_HOLD_EXIT=true
LIVE_SELECTION_MODE=seen_so_far_top_n
LIVE_USE_NEWS_PROXY=true

# Paper trading risk limits. These are separate from the strategy preset.
LIVE_MAX_DAILY_TRADES=2
LIVE_MAX_OPEN_POSITIONS=2
LIVE_MAX_ORDERS_PER_SYMBOL_PER_DAY=1
LIVE_MAX_DAILY_LOSS_DOLLARS=500

# Sizing mode: fixed_dollar_risk, percent_equity, or controlled_compounding.
LIVE_RISK_MODE=fixed_dollar_risk
LIVE_FIXED_RISK_DOLLARS=100
LIVE_ACCOUNT_VALUE_FALLBACK=10000
LIVE_BASE_RISK_PCT=1.0
LIVE_MIN_RISK_DOLLARS=10
LIVE_MAX_RISK_DOLLARS=100
LIVE_DD1_RISK_PCT=0.75
LIVE_DD2_RISK_PCT=0.50
LIVE_PAUSE_DD_PCT=15
LIVE_ALLOW_FRACTIONAL_SHARES=false
